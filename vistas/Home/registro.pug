doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title Registro
    meta(name="viewport" content="width=device-width, initial-scale=1")

    // Bootstrap 5
    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

  body.bg-black
      .container.content-center.align-items-center.vh-100
        .card.shadow.p-4(style="width: 400px;")
          .col 
            h3.text-center.mb-4 Crea tu cuenta en nuestra comunidad
            form(action="/registro" method="POST")

              // Nombre
              .mb-3
                label.form-label Nombre
                input.form-control(
                  type="text"
                  name="nombre"
                  required
                )
              .mb-3
                label.form-label Apellido
                input.form-control(
                  type="text"
                  name="apellido"
                  required
                )
              // Email
              .mb-3
                label.form-label Nick que deseas usar
                input.form-control(
                  type="text"
                  name="nick"
                  required
                )

              // Contraseña
              .mb-3
                label.form-label Contraseña
                input.form-control(
                  type="password"
                  name="password"
                  required
                )
              .mb-3
                label.form-label Teléfono
                input.form-control(
                  type="text"
                  name="telefono"
                  required
                )
              // Email
              .mb-3
                label.form-label  E-mail
                input.form-control(
                  type="email"
                  name="mail"
                  required
                )
              // Términos
              .form-check.mb-3
                input.form-check-input(
                  type="checkbox"
                  required
                )
                label.form-check-label
                  | Acepto los términos y condiciones

              // Botón
              button.btn.btn-success.w-100(type="submit")
                | Registrarse

            p.text-center.mt-3.mb-0
              | ¿Ya tenés cuenta?
              a(href="/login")  Iniciar sesión

        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")