extends ./HomeUsuario
block content
  .row
    .col-1 
    .col-10.p-3
      .card.shadow.p-4(style="width: 400px;")
          h3.text-center POSTEASTE
          h6 Titulo: #{publicacion.titulo}
          h6 Descripción #{publicacion.descripcion};

      div
        h1.text-center Imágenes  
          .d-flex.flex.p-5
            each imagen in imagenesGuardadas
              .me-3
                a(href=`/imagen/${imagen.id}`)
                  img.rounded.shadow.p-1.bg-dark.p-1(
                    src=`/${imagen.urlImagen}`
                    alt="Imagen"
                    style="width:360px; height:500px; object-fit:cover;"
                  )
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js")