extends ./HomeUsuario

block content
    .row
    br
    .row 
        .col-3
        .col-6.bg-success.p-3.rounded
          #carouselFotos.carousel
            .carousel-inner.p-4
                each imagen, index in imagenes
                  .carousel-item(class=index === 0 ? 'active' : '')
                    //- La imagen y los botones deben ser hermanos, no hijos de img
                    a(href=`/imagen/${imagen.id}`)
                      img.d-block.w-100(
                        src=`/${imagen.urlImagen}`
                        alt="Imagen"
                        style="width:250px; height:250px; object-fit:cover;"
                      )
                    .mt-2.text-center
                        a.mx-2(href="#" onclick=`Votar('${imagen.id}')`)
                          i.fa.fa-star(title="VOTAR" style="font-size:25px; color: yellow;")
                        a.mx-2(href="#" onclick=`Comentar('${imagen.id}')`)
                          i.fa.fa-commenting(title="COMENTAR" style="font-size:25px; color: white;")
                        a.mx-2(href="#" onclick=`Denunciar('${imagen.id}')`)
                          i.fa.fa-exclamation-triangle(title="DENUNCUAR" style="font-size:25px; color: red;")
    
            //- Botones de control del carrusel
            button.carousel-control-prev(
              type="button"
              data-bs-target="#carouselFotos"
              data-bs-slide="prev"
            )
              span.carousel-control-prev-icon
            
            button.carousel-control-next(
              type="button"
              data-bs-target="#carouselFotos"
              data-bs-slide="next"
            )
              span.carousel-control-next-icon
    div.modal(tabindex="-1", id="votar")
            div.modal-dialog
              div.modal-content
                div.modal-header
                  h5.modal-title Votar Imagen
                  button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
                div.modal-body
                  form.row.g-3(action="/votar-imagen", method="post")
                    input(type="hidden", id="idVotada" name="idVotada")
                    .col-md-12
                      h5(class="form-label") Deseas votar: 
                    .col-12
                        label(for ="voto" class="form-label") Vota del 1 al 5 
                        input(type="number" class="form-control" name="voto" required min="1" max="5")
                    .col-12  
                    div.modal-footer
                      button(type="submit" class="btn btn-warning") Votar
                      button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close  

    div.modal(tabindex="-1", id="comentar")
          div.modal-dialog
            div.modal-content
              div.modal-header.bg-primary
                h5.modal-title Comentario
                button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
              div.modal-body
                form.row.g-3(action="/comentar-imagen", method="post")
                  input(type="hidden", id="idComentario" name="idComentario")
                  .col-md-12
                    h5(class="form-label") Que deseas comentar? 
                  .col-12
                      textarea(type="text" row= '4' class="form-control" name="comentario" required )
                  .col-12  
                  div.modal-footer
                    button(type="submit" class="btn btn-primary") Enviar comentario
                    button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close                  
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js")

    script.
         function Votar(idVotada) {
          document.querySelector("#idVotada").value = idVotada;
          var myModal = new bootstrap.Modal(document.getElementById('votar'));
          myModal.show();
         }
    script.
         function Comentar(idComentario) {
          document.querySelector("#idComentario").value = idComentario;
          var myModal = new bootstrap.Modal(document.getElementById('comentar'));
          myModal.show();
         }