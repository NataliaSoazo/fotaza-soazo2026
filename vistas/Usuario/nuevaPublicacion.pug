extends ./HomeUsuario

block content

  .container.d-flex.justify-content-center.align-items-center.vh-100

    .card.shadow.p-4(style="width: 400px;")
      h3.text-center.mb-4 Nueva Publicación

      // PREVIEWS
      div#imgsPreview.d-flex.flex-wrap.mb-3

      form(
        action="/nuevaPublicacion"
        method="POST"
        enctype="multipart/form-data"
      )

        .mb-3
          label.form-label Titulo

          input.form-control(
            type="text"
            name="titulo"
            required
          )

        .mb-3
          label.form-label Descripción

          textarea.form-control(
            name="descripcion"
            rows="4"
            required
          )

        .mb-3
          label.form-label 
          b Imágenes: 
          i (Elige hasta 10 juntas)

          input.form-control(
            type="file"
            id="img"
            name="img"
            accept="image/*"
            multiple=true
            required
          )

        // CONTENEDOR BASE64
        div#imgsBase64

        button.btn.btn-success.w-100(
          type="submit"
        )
          | Subir

        ul#errores.text-danger.mt-3

  script(src="/script.js")

  script(
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
  )

    script(
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
    )